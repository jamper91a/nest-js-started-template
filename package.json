    "@typescript-eslint/parser": "^4.33.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "7.2.0",
    "eslint-plugin-prettier": "^3.4.1",
    "jest": "^27.3.1",
    "prettier": "^2.4.1",
    "prisma": "^3.4.1",
    "run-script-webpack-plugin": "0.0.11",
    "supertest": "^6.1.6",
