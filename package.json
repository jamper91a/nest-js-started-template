    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^3.0.2",
    "rxjs": "^7.4.0",
    "sequelize": "^6.9.0",
    "sequelize-typescript": "^2.1.1",
    "underscore": "^1.13.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^8.1.4",
    "@nestjs/schematics": "^7.1.3",
    "@nestjs/testing": "^7.6.18",
